# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real keys.

# LLM provider: "anthropic" or "openai"
FORGE_LLM_PROVIDER=anthropic
FORGE_LLM_MODEL=claude-sonnet-4-6

# API keys (only the one matching FORGE_LLM_PROVIDER is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Pipeline knobs
FORGE_MAX_RETRIES=3

# Docker sandbox
FORGE_DOCKER_IMAGE=forge-sandbox:latest
FORGE_DOCKER_TIMEOUT=60
